aws_region        = "us-east-1"
project_name      = "jeopardy-rag"
instance_type     = "t3.small"
data_volume_size  = 20
ssh_public_key    = "ssh-ed25519 AAAA... you@host"
ssh_allowed_cidr  = "0.0.0.0/0"    # Lock to your IP: "1.2.3.4/32"
anthropic_api_key = ""              # Optional: set for real API calls
docker_image      = ""              # Leave empty to build from source on EC2
